<?xml version="1.0" encoding="utf-8"?>
<!-- Dark-mode splash. True black, matching the AMOLED dark theme and the icon
     tile, so the launch background and the first Flutter frame agree. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:drawable="@android:color/black" />

    <item>
        <bitmap
            android:gravity="center"
            android:src="@drawable/splash_mark_on_dark" />
    </item>
</layer-list>
